# API server
PORT=3001
API_KEY=change-me-in-production

# Postgres (local docker-compose defaults)
DATABASE_URL=postgresql://chronos:chronos@localhost:5432/chronos

# Redis (local docker-compose defaults)
REDIS_URL=redis://localhost:6379

# Worker identity (set per worker instance in production)
WORKER_ID=worker-01
WORKER_NAME=scheduler-primary-us-east
WORKER_REGION=us-east-1
WORKER_CAPACITY=200

# Frontend (Vite)
VITE_API_URL=

# Optional: seed demo data on startup (dev only)
SEED_DEMO_DATA=false
